# HTTP port (default 3000 if omitted).
PORT=3000

# Recommended: path to the service account JSON (each developer uses their own file locally).
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Alternative: full JSON on one line (use only where file paths are awkward; keep secret).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# If neither is set, the app loads ./firebase-key.json from the backend working directory (local dev only).
